@echo off
chcp 65001 >nul
echo ========================================================
echo 2026학년도 고사 HWP -> PDF 자동 변환 스케줄러 해제 (끄기)
echo ========================================================
echo.
echo [안내] 백그라운드에서 실행 중인 한글 파일 자동 PDF 변환 
echo        스케줄러를 해제(종료)합니다.
echo        이 작업은 원안 작성 도중 한글이 강제 종료되는 등의
echo        현상을 방지하기 위해 권장됩니다.
echo.
echo 실행하려면 아무 키나 누르세요... (Ctrl+C를 누르면 취소됩니다)
pause >nul

set TASK_NAME="Auto Convert HWP to PDF"

:: 스케줄러 작업 삭제
schtasks /delete /tn %TASK_NAME% /f

echo.
echo --------------------------------------------------------
echo [완료] HWP -> PDF 자동 변환 스케줄러가 해제되었습니다.
echo        이제 백그라운드 자동 변환이 실행되지 않습니다.
echo --------------------------------------------------------
echo.
pause
